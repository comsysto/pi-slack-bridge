{
  "name": "pi-slack-bridge",
  "version": "0.4.0",
  "description": "Bridge Slack into pi \u2014 a pure Slack remote control surface for the pi coding agent",
  "main": "dist/bridge/index.js",
  "types": "dist/bridge/index.d.ts",
  "pi": {
    "extensions": [
      "./dist/bridge/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "slack",
    "bridge",
    "bot",
    "remote",
    "chat",
    "messaging",
    "coding-agent"
  ],
  "author": "tintinweb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tintinweb/pi-slack-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/tintinweb/pi-slack-bridge/issues"
  },
  "homepage": "https://github.com/tintinweb/pi-slack-bridge#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74",
    "@earendil-works/pi-coding-agent": ">=0.74",
    "@earendil-works/pi-tui": ">=0.74"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.2",
    "fast-check": "^4.5.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "type": "module"
}
